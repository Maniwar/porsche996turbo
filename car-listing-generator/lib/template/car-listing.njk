<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>{{ car.meta.title }}</title>
<meta name="description" content="{{ car.meta.description }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
<style>
:root {
  --red:      {{ car.identity.accentColor }};
  --red-b:    {{ car.identity.accentColor }};
  --red-glow: {{ car.identity.accentColor }}30;
  --gold:     #c9a875;
  --gold-d:   #8a6e40;
  --bg:       #080808;
  --bg-1:     #0f0f0f;
  --bg-2:     #141414;
  --bg-3:     #1a1a1a;
  --border:   #222;
  --text:     #e8e8e8;
  --dim:      #888;
  --muted:    #555;
  --radius:   12px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--text);font-family:'Inter',sans-serif;line-height:1.6;-webkit-font-smoothing:antialiased}
.container{max-width:1080px;margin:0 auto;padding:0 24px}
.eyebrow{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.sh{font-size:clamp(26px,4vw,40px);font-weight:800;line-height:1.15;margin-bottom:16px}
.sp{font-size:15px;color:var(--dim);line-height:1.8;max-width:640px;margin:0 auto}

/* RV scroll reveal */
.rv{opacity:0;transform:translateY(32px);transition:opacity 0.7s ease,transform 0.7s ease}
.rv.in{opacity:1;transform:none}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:900;padding:16px 28px;display:flex;align-items:center;justify-content:space-between;background:rgba(8,8,8,0.85);backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,0.04)}
.nav-brand{font-size:13px;font-weight:600;color:var(--text);letter-spacing:-0.02em}
.nav-cta{font-size:12px;background:var(--red);color:#fff;padding:7px 16px;border-radius:6px;text-decoration:none;font-weight:600;transition:opacity 0.2s}
.nav-cta:hover{opacity:0.85}

/* HERO */
.hero{height:100vh;min-height:600px;position:relative;overflow:hidden;display:flex;align-items:flex-end}
.hero-frames{position:absolute;inset:0;z-index:0}
.hero-frame{position:absolute;inset:0;background-size:cover;background-position:center;opacity:0;transition:opacity 0.8s ease}
.hero-frame.active{opacity:1}
.hero-video{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(0.75)}
{% if not car.hasFrames and not car.hasVideo %}
.hero-frame-static{position:absolute;inset:0;background:url('{{ car.photoNames[0] }}') center/cover no-repeat;filter:brightness(0.7)}
{% endif %}
.hero-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,0.85) 0%,rgba(0,0,0,0.2) 60%,transparent 100%);z-index:1}
.hero-content{position:relative;z-index:2;padding:52px 40px;max-width:800px}
.hero-pill{display:inline-block;border:1px solid rgba(255,255,255,0.15);border-radius:20px;padding:5px 14px;font-size:11px;letter-spacing:0.1em;text-transform:uppercase;color:rgba(255,255,255,0.6);margin-bottom:20px}
.hero-h1{font-size:clamp(36px,6vw,68px);font-weight:900;line-height:1.05;margin-bottom:14px;letter-spacing:-0.03em}
.hero-h1 em{color:var(--red);font-style:normal}
.hero-sub{font-size:14px;color:rgba(255,255,255,0.55);letter-spacing:0.05em;margin-bottom:32px}
.hero-actions{display:flex;gap:12px;flex-wrap:wrap}
.btn-primary{background:var(--red);color:#fff;padding:12px 28px;border-radius:8px;font-size:14px;font-weight:700;text-decoration:none;transition:opacity 0.2s}
.btn-primary:hover{opacity:0.85}
.btn-outline{border:1px solid rgba(255,255,255,0.2);color:rgba(255,255,255,0.7);padding:12px 28px;border-radius:8px;font-size:14px;font-weight:600;cursor:pointer;background:none;transition:border-color 0.2s,color 0.2s}
.btn-outline:hover{border-color:rgba(255,255,255,0.5);color:#fff}

/* SNAP CELLS */
.snap-strip{background:var(--bg-1);border-bottom:1px solid var(--border);padding:20px 0}
.snap-cells{display:flex;flex-wrap:wrap;justify-content:center;gap:0}
.snap-cell{padding:16px 28px;border-right:1px solid var(--border);text-align:center}
.snap-cell:last-child{border-right:none}
.sc-v{font-size:15px;font-weight:700;color:var(--text)}
.sc-v.gold{color:var(--gold)}
.sc-l{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-top:2px}

/* HIGHLIGHT CARDS */
.hl-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.hl-card{--mx:50%;--my:50%;background:radial-gradient(240px circle at var(--mx) var(--my),rgba(191,58,28,0.07),transparent 60%),var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);padding:28px;position:relative;overflow:hidden;transition:border-color 0.3s,transform 0.25s,box-shadow 0.3s}
.hl-card::after{content:'';position:absolute;inset:0 0 auto;height:2px;background:linear-gradient(to right,transparent,var(--red),transparent);opacity:0;transition:opacity 0.3s}
.hl-card:hover{border-color:rgba(191,58,28,0.45);transform:translateY(-3px);box-shadow:0 16px 48px rgba(191,58,28,0.08)}
.hl-card:hover::after{opacity:1}
.hl-icon{width:46px;height:46px;border-radius:9px;background:rgba(191,58,28,0.12);border:1px solid rgba(191,58,28,0.28);display:flex;align-items:center;justify-content:center;color:var(--red);margin-bottom:18px}
.hl-card h4{font-size:17px;font-weight:700;margin-bottom:10px}
.hl-card p{font-size:14px;color:var(--dim);line-height:1.72}

/* SPECS */
.specs-grid{display:grid;grid-template-columns:1fr 1fr;gap:40px}
.spec-table{width:100%;border-collapse:collapse}
.spec-table tr{border-bottom:1px solid var(--border)}
.spec-table td{padding:11px 0;font-size:14px;vertical-align:top}
.spec-table td:first-child{color:var(--muted);width:45%;padding-right:16px}
.spec-table td:last-child{font-weight:500;color:var(--text)}
.spec-table td.gold{color:var(--gold)}

/* SERVICE */
.svc-timeline{position:relative;padding-left:32px}
.svc-timeline::before{content:'';position:absolute;left:8px;top:0;bottom:0;width:1px;background:var(--border)}
.svc-item{display:flex;gap:20px;margin-bottom:32px}
.svc-dot{width:16px;height:16px;border-radius:50%;background:var(--bg-2);border:2px solid var(--border);flex-shrink:0;margin-top:4px}
.svc-item.featured .svc-dot{background:var(--red);border-color:var(--red)}
.svc-card{flex:1;background:var(--bg-1);border:1px solid var(--border);border-radius:10px;padding:20px}
.svc-item.featured .svc-card{border-color:rgba(191,58,28,0.3)}
.svc-meta{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:12px}
.svc-date{font-size:11px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;margin-bottom:4px}
.svc-title{font-size:15px;font-weight:700}
.svc-total{font-size:18px;font-weight:800;color:var(--red)}
.svc-items{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:12px}
.svc-tag{font-size:11px;padding:3px 10px;border-radius:20px;background:var(--bg-2);border:1px solid var(--border);color:var(--dim)}
.svc-tag.key{border-color:rgba(191,58,28,0.3);color:var(--red-b);background:rgba(191,58,28,0.06)}
.svc-shop-badge{font-size:11px;color:var(--muted);padding-top:8px;border-top:1px solid var(--border)}

/* TIP CARD */
.tip-card{--mx:50%;--my:50%;background:radial-gradient(360px circle at var(--mx) var(--my),rgba(201,168,117,0.07),transparent 60%),var(--bg-1);border:1px solid var(--border);border-radius:var(--radius);padding:28px;position:relative;overflow:hidden;transition:border-color 0.3s,transform 0.25s,box-shadow 0.3s;margin-top:24px}
.tip-card::after{content:'';position:absolute;inset:0 0 auto;height:2px;background:linear-gradient(to right,transparent,var(--gold),transparent);opacity:0;transition:opacity 0.3s}
.tip-card:hover{border-color:rgba(201,168,117,0.45);transform:translateY(-3px);box-shadow:0 16px 48px rgba(201,168,117,0.08)}
.tip-card:hover::after{opacity:1}
.tip-icon{width:46px;height:46px;border-radius:9px;background:rgba(201,168,117,0.12);border:1px solid rgba(201,168,117,0.28);display:flex;align-items:center;justify-content:center;color:var(--gold);margin-bottom:18px}
.tip-card h4{font-size:17px;font-weight:700;margin-bottom:10px}
.tip-card h4 span{color:var(--gold)}
.tip-teaser{font-size:14px;color:var(--dim);line-height:1.72}
.tip-body{max-height:0;overflow:hidden;transition:max-height 0.5s ease}
.tip-body.open{max-height:4000px}
.tip-body p{font-size:14px;color:var(--dim);line-height:1.72;margin-top:12px}
.tip-toggle{background:none;border:none;color:var(--gold);font-size:13px;cursor:pointer;padding:10px 0 0;display:flex;align-items:center;gap:6px;letter-spacing:0.04em;font-family:inherit}
.tip-toggle svg{transition:transform 0.3s}
.tip-toggle.open svg{transform:rotate(180deg)}
.tip-specs{display:flex;gap:10px;flex-wrap:wrap;margin-top:20px}
.tip-card.rv .tip-spec{opacity:0;transform:translateY(14px);transition:opacity 0.45s ease,transform 0.45s ease}
.tip-card.rv.in .tip-spec{opacity:1;transform:none}
.tip-card.rv.in .tip-spec:nth-child(2){transition-delay:0.12s}
.tip-card.rv.in .tip-spec:nth-child(3){transition-delay:0.24s}
.tip-card.rv.in .tip-spec:nth-child(4){transition-delay:0.36s}
.tip-spec{text-align:center;padding:12px 20px;background:rgba(201,168,117,0.07);border:1px solid rgba(201,168,117,0.18);border-radius:8px;flex:1;min-width:120px}
.tip-spec-v{font-size:17px;font-weight:700;color:var(--gold);display:block}
.tip-spec-l{font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;display:block;margin-top:2px}

/* RARITY */
.rarity-block{margin-top:60px;background:linear-gradient(135deg,#160808 0%,#0a0404 100%);border:1px solid rgba(191,58,28,0.22);border-radius:14px;padding:52px 56px;display:grid;grid-template-columns:1fr auto;gap:52px;align-items:center}
.rarity-block h3{font-size:26px;font-weight:800;margin-bottom:14px}
.rarity-block p{color:var(--dim);font-size:15px;line-height:1.8;margin-bottom:12px}
.rarity-em{color:var(--gold)}
.rarity-claim{color:var(--red);font-weight:600;margin-top:4px}
.rarity-badge{text-align:center;border:1px solid rgba(191,58,28,0.3);border-radius:14px;padding:32px 28px;min-width:140px}
.rn{font-size:64px;font-weight:900;color:var(--red);display:block;line-height:1}
.rl{font-size:11px;color:var(--muted);letter-spacing:0.08em;text-transform:uppercase;margin-top:8px;display:block;line-height:1.6}

/* CONDITION */
.cond-section{background:var(--bg-1)}
.cond-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-top:32px}
.cond-photo{position:relative;cursor:pointer;border-radius:8px;overflow:hidden;border:1px solid var(--border);aspect-ratio:4/3}
.cond-photo img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s}
.cond-photo:hover img{transform:scale(1.04)}
.cond-photo span{position:absolute;bottom:0;left:0;right:0;padding:8px 12px;background:linear-gradient(transparent,rgba(0,0,0,0.82));font-size:11px;color:rgba(255,255,255,0.75);letter-spacing:0.04em}

/* CONTACT */
.contact-section{background:var(--bg-1);text-align:center}
.contact-cards{display:grid;grid-template-columns:repeat(2,1fr);gap:12px;max-width:480px;margin:0 auto}
.cc-card{display:flex;align-items:center;gap:12px;background:var(--bg-2);border:1px solid var(--border);border-radius:10px;padding:16px 20px;text-decoration:none;color:var(--text);transition:border-color 0.2s}
.cc-card:hover{border-color:var(--red)}
.cc-icon{width:36px;height:36px;border-radius:8px;background:rgba(191,58,28,0.12);border:1px solid rgba(191,58,28,0.25);display:flex;align-items:center;justify-content:center;color:var(--red);flex-shrink:0}
.cc-label{font-size:13px;font-weight:600}

/* LIGHTBOX */
.lb{position:fixed;inset:0;z-index:2000;background:rgba(0,0,0,0.97);display:none;flex-direction:column;align-items:center;justify-content:center}
.lb.open{display:flex}
.lb-img{max-width:90vw;max-height:80vh;object-fit:contain;border-radius:4px}
.lb-close{position:absolute;top:20px;right:24px;background:none;border:none;color:rgba(255,255,255,0.6);font-size:28px;cursor:pointer;line-height:1}
.lb-nav{position:absolute;top:50%;transform:translateY(-50%);background:rgba(255,255,255,0.08);border:none;color:white;font-size:24px;padding:16px;cursor:pointer;border-radius:4px}
.lb-prev{left:16px}
.lb-next{right:16px}
.lb-cap{position:absolute;bottom:24px;left:0;right:0;text-align:center;font-size:13px;color:rgba(255,255,255,0.5)}
.lb-ctr{position:absolute;top:20px;left:24px;font-size:12px;color:rgba(255,255,255,0.4)}

/* SECTIONS */
section{padding:100px 0}
section:nth-child(even){background:var(--bg-1)}
.section-pad{padding:80px 0}

/* PHOTO STRIP */
.photo-strip{display:grid;gap:4px}
.photo-strip.three-col{grid-template-columns:2fr 1fr 1fr}
.ps-item{position:relative;overflow:hidden;cursor:pointer;background:var(--bg-2)}
.ps-item img{width:100%;height:280px;object-fit:cover;display:block;transition:transform 0.4s}
.ps-item:hover img{transform:scale(1.03)}
.ps-cap{position:absolute;bottom:0;left:0;right:0;padding:12px 16px;background:linear-gradient(transparent,rgba(0,0,0,0.7))}
.ps-cap-text{font-size:12px;color:rgba(255,255,255,0.7);letter-spacing:0.05em}

/* GALLERY GRID */
.gallery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:6px;grid-auto-rows:220px}
.gallery-grid .main{grid-column:span 3;grid-row:span 2}
.g-item{overflow:hidden;cursor:pointer;border-radius:4px;background:var(--bg-2)}
.g-item img{width:100%;height:100%;object-fit:cover;transition:transform 0.4s;display:block}
.g-item:hover img{transform:scale(1.05)}
.gallery-more{margin-top:14px;text-align:center;font-size:13px;color:var(--muted);cursor:pointer;transition:color 0.2s}
.gallery-more:hover{color:var(--dim)}

/* INVEST STRIP */
.invest-strip{background:var(--bg-1);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:32px 0}
.invest-cells{display:flex;flex-wrap:wrap;justify-content:center;gap:48px;align-items:center}
.invest-n{font-size:36px;font-weight:900;color:var(--text)}
.invest-n span{color:var(--red)}
.invest-l{font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:0.1em;margin-top:2px}
.invest-divider{width:1px;height:48px;background:var(--border)}
.invest-shop{font-size:13px;color:var(--dim);line-height:1.6}
.invest-shop strong{color:var(--text);display:block}

/* FOOTER */
footer{background:#000;border-top:1px solid var(--border);padding:32px 0;text-align:center}
footer p{font-size:12px;color:var(--muted);line-height:2}

/* SOUND / YOUTUBE */
.sound-section{background:var(--bg);text-align:center}
.sound-thumb-wrap{position:relative;display:inline-block;cursor:pointer;border-radius:12px;overflow:hidden;max-width:640px;width:100%;margin:0 auto}
.sound-thumb-wrap img{width:100%;display:block;filter:brightness(0.7)}
.play-btn{position:absolute;inset:0;display:flex;align-items:center;justify-content:center}
.play-btn svg{filter:drop-shadow(0 4px 24px rgba(0,0,0,0.5))}

@media(max-width:900px){
  .hl-grid{grid-template-columns:1fr 1fr}
  .rarity-block{grid-template-columns:1fr;gap:32px}
  .specs-grid{grid-template-columns:1fr}
  .cond-grid{grid-template-columns:repeat(2,1fr)}
}
@media(max-width:600px){
  .hl-grid{grid-template-columns:1fr}
  .hero-content{padding:32px 20px}
  .gallery-grid{grid-template-columns:1fr 1fr}
  .gallery-grid .main{grid-column:span 2}
  .contact-cards{grid-template-columns:1fr;max-width:320px}
  .photo-strip.three-col{grid-template-columns:1fr 1fr}
  .invest-cells{gap:24px}
  .invest-divider{display:none}
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <div class="nav-brand">{{ car.identity.year }} {{ car.identity.make }} {{ car.identity.model }}</div>
  <a href="mailto:{{ car.identity.email }}" class="nav-cta">Inquire</a>
</nav>

<!-- HERO -->
<div class="hero">
  <div class="hero-frames" id="heroFrames">
    {% if car.hasVideo %}
    <video class="hero-video" autoplay loop muted playsinline>
      <source src="hero-video.mp4" type="video/mp4">
    </video>
    {% elif car.hasFrames %}
    <!-- frames injected by JS -->
    {% else %}
    <div class="hero-frame-static"></div>
    {% endif %}
  </div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-pill">{{ car.hero.pill }}</div>
    <h1 class="hero-h1">{{ car.hero.headline | safe }}</h1>
    <div class="hero-sub">{{ car.hero.subline }}</div>
    <div class="hero-actions">
      <a href="mailto:{{ car.identity.email }}" class="btn-primary">Request Info</a>
      <button class="btn-outline" onclick="document.querySelector('.snap-strip').scrollIntoView({behavior:'smooth'})">View Specs</button>
    </div>
  </div>
</div>

<!-- SNAP CELLS -->
<div class="snap-strip">
  <div class="snap-cells">
    {% for cell in car.snapCells %}
    <div class="snap-cell">
      <div class="sc-v {% if cell.gold %}gold{% endif %}">{{ cell.value }}</div>
      <div class="sc-l">{{ cell.label }}</div>
    </div>
    {% endfor %}
  </div>
</div>

<!-- GALLERY -->
<section>
  <div class="container">
    <div class="eyebrow rv">Gallery</div>
    <h2 class="sh rv">{{ car.identity.colorName }}</h2>
    <div class="gallery-grid rv">
      {% for photo in car.photoNames %}
        {% if loop.index <= 9 %}
        <div class="g-item {% if loop.first %}main{% endif %}" onclick="openLb({{ loop.index0 }})">
          <img src="{{ photo }}" alt="{{ car.identity.colorName }} {{ car.identity.model }}" loading="{% if loop.first %}eager{% else %}lazy{% endif %}">
        </div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="gallery-more rv" onclick="openLb(9)">+ more photos — click to browse all {{ car.lightboxPhotos | length }}</div>
  </div>
</section>

<!-- INVEST STRIP -->
{% if car.service %}
<div class="invest-strip">
  <div class="container">
    <div class="invest-cells">
      <div>
        <div class="invest-n">$<span id="ctrTotal">0</span></div>
        <div class="invest-l">Service Investment</div>
      </div>
      <div class="invest-divider"></div>
      <div>
        <div class="invest-n"><span id="ctrVisits">0</span></div>
        <div class="invest-l">Documented Visits</div>
      </div>
      <div class="invest-divider"></div>
      <div class="invest-shop">
        <strong>{{ car.service.shopName }}</strong>
        {{ car.service.shopSubName }} — {{ car.service.shopLocation }}
      </div>
    </div>
  </div>
</div>
{% endif %}

<!-- HIGHLIGHTS -->
<section>
  <div class="container">
    <div class="eyebrow rv">Why This Car</div>
    <h2 class="sh rv">The Case For It</h2>
    <div class="hl-grid">
      {% for card in car.highlightCards %}
      <div class="hl-card js-glow rv">
        <div class="hl-icon">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            {% if card.icon == 'star' %}<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
            {% elif card.icon == 'clock' %}<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
            {% elif card.icon == 'shield' %}<path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            {% elif card.icon == 'document' %}<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            {% elif card.icon == 'heart' %}<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
            {% elif card.icon == 'bolt' %}<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            {% elif card.icon == 'wrench' %}<path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
            {% elif card.icon == 'gauge' %}<path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 12L8 8"/>
            {% else %}<circle cx="12" cy="12" r="10"/>{% endif %}
          </svg>
        </div>
        <h4>{{ card.title }}</h4>
        <p>{{ card.body }}</p>
      </div>
      {% endfor %}
    </div>

    {% if car.transmissionCard and car.transmissionCard.enabled %}
    <div class="tip-card rv js-glow">
      <div class="tip-icon">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 0 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 0 1-2.83-2.83l.06-.06A1.65 1.65 0 0 0 4.68 15a1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 0 1 2.83-2.83l.06.06A1.65 1.65 0 0 0 9 4.68a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 0 1 2.83 2.83l-.06.06A1.65 1.65 0 0 0 19.4 9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
      </div>
      <h4>{{ car.transmissionCard.title }} <span>{{ car.transmissionCard.titleAccent }}</span></h4>
      <p class="tip-teaser">{{ car.transmissionCard.teaser }}</p>
      <div class="tip-body" id="tipBody">
        <p>{{ car.transmissionCard.body }}</p>
      </div>
      <button class="tip-toggle" id="tipToggle" onclick="(function(){var b=document.getElementById('tipBody'),t=document.getElementById('tipToggle'),isOpen=b.classList.toggle('open');b.style.maxHeight=isOpen?b.scrollHeight+'px':'0';t.classList.toggle('open');t.querySelector('span').textContent=isOpen?'Show less':'Read full argument';})()">
        <span>Read full argument</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
      </button>
      {% if car.transmissionCard.specs %}
      <div class="tip-specs">
        {% for spec in car.transmissionCard.specs %}
        <div class="tip-spec"><span class="tip-spec-v">{{ spec.value }}</span><span class="tip-spec-l">{{ spec.label }}</span></div>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endif %}

    {% if car.rarityBlock and car.rarityBlock.enabled %}
    <div class="rarity-block rv">
      <div>
        <h3>{{ car.rarityBlock.headline }}</h3>
        {% for para in car.rarityBlock.paragraphs %}
        <p>{{ para | safe }}</p>
        {% endfor %}
        {% if car.rarityBlock.boldClaim %}<p><strong class="rarity-em">{{ car.rarityBlock.boldClaim }}</strong></p>{% endif %}
        {% if car.rarityBlock.finalClaim %}<p class="rarity-claim">{{ car.rarityBlock.finalClaim }}</p>{% endif %}
      </div>
      <div class="rarity-badge">
        <span class="rn">{{ car.rarityBlock.badgeNumber }}</span>
        <span class="rl">{{ car.rarityBlock.badgeLabel }}</span>
      </div>
    </div>
    {% endif %}
  </div>
</section>

<!-- SPECS -->
<section>
  <div class="container">
    <div class="eyebrow rv">Specifications</div>
    <h2 class="sh rv">By The Numbers</h2>
    <div class="specs-grid rv">
      <div>
        <table class="spec-table">
          {% for row in car.specsIdentity %}
          <tr><td>{{ row.key }}</td><td class="{% if row.gold %}gold{% endif %}">{{ row.value }}</td></tr>
          {% endfor %}
        </table>
      </div>
      <div>
        <table class="spec-table">
          {% for row in car.specsPowertrain %}
          <tr><td>{{ row.key }}</td><td class="{% if row.gold %}gold{% endif %}">{{ row.value }}</td></tr>
          {% endfor %}
        </table>
        {% if car.specsEquipment and car.specsEquipment.length %}
        <table class="spec-table" style="margin-top:24px">
          {% for row in car.specsEquipment %}
          <tr><td>{{ row.key }}</td><td>{{ row.value }}</td></tr>
          {% endfor %}
        </table>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<!-- SERVICE HISTORY -->
{% if car.service and car.service.visits %}
<section>
  <div class="container">
    <div class="eyebrow rv">Service History</div>
    <h2 class="sh rv">{{ car.service.headline }}</h2>
    <p class="sp rv" style="margin-bottom:48px;text-align:left;max-width:100%">{{ car.service.subheadline }}</p>
    <div class="svc-timeline">
      {% for visit in car.service.visits %}
      <div class="svc-item {% if visit.featured %}featured{% endif %}">
        <div style="padding-top:4px;flex-shrink:0">
          <div class="svc-dot"></div>
        </div>
        <div class="svc-card rv">
          <div class="svc-meta">
            <div>
              <div class="svc-date">{{ visit.date }} &nbsp;&middot;&nbsp; {{ visit.mileage }} miles</div>
              <div class="svc-title">{{ visit.title }}</div>
            </div>
            <div class="svc-total">{{ visit.cost }}</div>
          </div>
          <div class="svc-items">
            {% for item in visit.items %}
            <span class="svc-tag {% if item.key %}key{% endif %}">{{ item.label }}</span>
            {% endfor %}
          </div>
          {% if visit.invoiceRef %}<div class="svc-shop-badge">{{ visit.shop }} &nbsp;&middot;&nbsp; {{ visit.invoiceRef }}</div>{% endif %}
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- YOUTUBE / SOUND -->
{% if car.identity.youtubeId %}
<section class="sound-section">
  <div class="container">
    <div class="eyebrow rv">Video</div>
    <h2 class="sh rv" style="text-align:center">Hear It</h2>
    <div class="sound-thumb-wrap rv" id="ytWrap">
      <img src="https://img.youtube.com/vi/{{ car.identity.youtubeId }}/maxresdefault.jpg" alt="Video thumbnail">
      <div class="play-btn">
        <svg width="72" height="72" viewBox="0 0 24 24" fill="rgba(255,255,255,0.9)"><circle cx="12" cy="12" r="12" fill="rgba(0,0,0,0.5)"/><polygon points="10 8 16 12 10 16 10 8" fill="white"/></svg>
      </div>
    </div>
  </div>
</section>
{% endif %}

<!-- PHOTO STRIP -->
{% if car.photoNames | length > 1 %}
<div class="photo-strip three-col">
  {% for photo in car.photoNames %}
    {% if loop.index > 1 and loop.index <= 4 %}
    <div class="ps-item" onclick="openLb({{ loop.index0 }})">
      <img src="{{ photo }}" alt="{{ car.identity.colorName }}" loading="lazy">
      <div class="ps-cap"><span class="ps-cap-text">{{ car.identity.colorName }}</span></div>
    </div>
    {% endif %}
  {% endfor %}
</div>
{% endif %}

<!-- CONDITION DISCLOSURE -->
{% if car.cosmeticDisclosure and car.cosmeticDisclosure.enabled and car.conditionPhotoNames | length %}
<section class="cond-section">
  <div class="container">
    <div class="eyebrow rv">Full Disclosure</div>
    <h2 class="sh rv">{{ car.cosmeticDisclosure.headline }}</h2>
    <p class="sp rv">{{ car.cosmeticDisclosure.disclosure }}</p>
    <div class="cond-grid rv">
      {% for photo in car.conditionPhotoNames %}
      <div class="cond-photo" onclick="openLb({{ car.conditionPhotoStartIndex + loop.index0 }})">
        <img src="{{ photo }}" loading="lazy" alt="Condition photo">
        <span>{{ photo }}</span>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- CONTACT -->
<section class="contact-section">
  <div class="container">
    <div class="eyebrow rv">Get In Touch</div>
    <h2 class="sh rv">{{ car.contact.headline }}</h2>
    <p class="sp rv">{{ car.contact.body }}</p>
    <div class="contact-cards rv" style="margin-top:32px">
      <a href="mailto:{{ car.identity.email }}" class="cc-card">
        <div class="cc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg></div>
        <div><div class="cc-label">Email</div><div style="font-size:12px;color:var(--muted)">{{ car.identity.email }}</div></div>
      </a>
      <button class="cc-card" onclick="navigator.clipboard.writeText('{{ car.identity.vin }}').then(()=>alert('VIN copied'))">
        <div class="cc-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg></div>
        <div><div class="cc-label">Copy VIN</div><div style="font-size:11px;color:var(--muted);font-family:monospace">{{ car.identity.vin }}</div></div>
      </button>
    </div>
    {% if car.contact.note %}<p class="rv" style="margin-top:24px;font-size:13px;color:var(--muted);text-align:center">{{ car.contact.note }}</p>{% endif %}
  </div>
</section>

<!-- FOOTER -->
<footer>
  <div class="container">
    <p>{{ car.identity.year }} {{ car.identity.make }} {{ car.identity.model }} &nbsp;&middot;&nbsp; VIN {{ car.identity.vin }} &nbsp;&middot;&nbsp; {{ car.identity.location }}</p>
    <p style="margin-top:4px">{{ car.identity.colorName }} &nbsp;&middot;&nbsp; {{ car.identity.price }}</p>
  </div>
</footer>

<!-- LIGHTBOX -->
<div class="lb" id="lb">
  <button class="lb-close" onclick="closeLb()">&times;</button>
  <span class="lb-ctr" id="lbCtr"></span>
  <img class="lb-img" id="lbImg" src="" alt="">
  <div class="lb-cap" id="lbCap"></div>
  <button class="lb-nav lb-prev" onclick="moveLb(-1)">&#8249;</button>
  <button class="lb-nav lb-next" onclick="moveLb(1)">&#8250;</button>
</div>

{% if car.audioFileName %}
<audio id="bgAudio" loop preload="none"><source src="{{ car.audioFileName }}" type="audio/mpeg"></audio>
{% endif %}

<script>
// PHOTOS array
const PHOTOS = [
  {% for p in car.lightboxPhotos %}
  { src: '{{ p.src }}', cap: '{{ p.cap | replace("'", "\\'") }}' }{% if not loop.last %},{% endif %}
  {% endfor %}
];

// Lightbox
let cur = 0;
const lbEl = document.getElementById('lb');
const lbImg = document.getElementById('lbImg');
const lbCtr = document.getElementById('lbCtr');
const lbCap = document.getElementById('lbCap');

function openLb(idx) {
  cur = ((idx % PHOTOS.length) + PHOTOS.length) % PHOTOS.length;
  renderLb();
  lbEl.classList.add('open');
  document.body.style.overflow = 'hidden';
}
function closeLb() { lbEl.classList.remove('open'); document.body.style.overflow = ''; }
function moveLb(dir) { cur = (cur + dir + PHOTOS.length) % PHOTOS.length; renderLb(); }
function renderLb() {
  const p = PHOTOS[cur];
  lbImg.src = p.src;
  lbCtr.textContent = (cur + 1) + ' / ' + PHOTOS.length;
  lbCap.textContent = p.cap;
}
document.addEventListener('keydown', e => {
  if (!lbEl.classList.contains('open')) return;
  if (e.key === 'Escape') closeLb();
  if (e.key === 'ArrowLeft') moveLb(-1);
  if (e.key === 'ArrowRight') moveLb(1);
});

// Scroll reveal
const rvObs = new IntersectionObserver(entries => {
  entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); rvObs.unobserve(e.target); } });
}, { threshold: 0.12 });
document.querySelectorAll('.rv').forEach(el => rvObs.observe(el));

// js-glow
document.querySelectorAll('.js-glow').forEach(card => {
  card.addEventListener('mousemove', e => {
    const r = card.getBoundingClientRect();
    card.style.setProperty('--mx', (e.clientX - r.left) + 'px');
    card.style.setProperty('--my', (e.clientY - r.top) + 'px');
  });
});

// Hero frames
{% if car.hasFrames %}
const FRAME_COUNT = {{ car.frameCount }};
const frames = [];
for (let i = 1; i <= FRAME_COUNT; i++) {
  const img = new Image();
  img.src = 'frames/frame_' + String(i).padStart(3, '0') + '.jpg';
  frames.push(img);
}
let frameIdx = 0;
const heroDiv = document.getElementById('heroFrames');
frames.forEach((img, i) => {
  const div = document.createElement('div');
  div.className = 'hero-frame' + (i === 0 ? ' active' : '');
  div.style.backgroundImage = 'url(' + img.src + ')';
  heroDiv.appendChild(div);
});
setInterval(() => {
  const els = heroDiv.querySelectorAll('.hero-frame');
  els[frameIdx].classList.remove('active');
  frameIdx = (frameIdx + 1) % FRAME_COUNT;
  els[frameIdx].classList.add('active');
}, 100);
{% endif %}

// Service counter
{% if car.service %}
function countUp(el, target, duration) {
  const start = performance.now();
  function step(now) {
    const t = Math.min((now - start) / duration, 1);
    const ease = t < 0.5 ? 4*t*t*t : 1 - Math.pow(-2*t+2, 3)/2;
    el.textContent = Math.round(ease * target).toLocaleString();
    if (t < 1) requestAnimationFrame(step);
  }
  requestAnimationFrame(step);
}
const strip = document.querySelector('.invest-strip');
if (strip) {
  let fired = false;
  new IntersectionObserver(entries => {
    if (entries[0].isIntersecting && !fired) {
      fired = true;
      countUp(document.getElementById('ctrTotal'), {{ car.service.totalRaw or 0 }}, 2000);
      countUp(document.getElementById('ctrVisits'), {{ car.service.visitCount or 0 }}, 1200);
    }
  }, { threshold: 0.4 }).observe(strip);
}
{% endif %}

// YouTube tap-to-play
const ytWrap = document.getElementById('ytWrap');
if (ytWrap) {
  ytWrap.addEventListener('click', () => {
    ytWrap.innerHTML = '<iframe width="100%" height="360" src="https://www.youtube.com/embed/{{ car.identity.youtubeId }}?autoplay=1&rel=0" frameborder="0" allowfullscreen allow="autoplay"></iframe>';
  });
}
</script>
</body>
</html>
